{
  "manifest_version": 3,
  "name": "Orange Names for Hacker News",
  "version": "0.1.0",
  "description": "Highlights notable commenters on Hacker News list pages.",
  "permissions": ["storage"],
  "host_permissions": ["https://hn.algolia.com/*"],
  "background": {
    "service_worker": "background-chrome.js"
  },
  "content_scripts": [
    {
      "matches": ["https://news.ycombinator.com/*"],
      "js": ["browser-polyfill.js", "notables.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
